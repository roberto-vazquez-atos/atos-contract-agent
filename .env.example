ANTHROPIC_API_KEY=your_api_key_here
DB_PATH=data/contracts.duckdb

# App login password — leave blank to disable authentication (not recommended for production)
APP_PASSWORD=your_password_here

# DuckDB encryption key — leave blank to store the database unencrypted
# WARNING: changing this after data has been stored requires re-initializing the database
DB_ENCRYPTION_KEY=
